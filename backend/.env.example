# 智肤康·皮肤疾病AI全流程辅助诊疗系统
# 环境配置示例

# 应用配置
APP_NAME=智肤康·皮肤疾病AI全流程辅助诊疗系统
APP_VERSION=1.0.0
DEBUG=true

# 服务器
HOST=0.0.0.0
PORT=8000

# 数据库
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=skin_diagnosis

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
SECRET_KEY=your-secret-key-change-in-production-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 文件上传
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# AI模型
MODEL_PATH=E:/py项目/Skin diseases/model
CLASSIFICATION_MODEL=efficientnet_b3.pth

# LLM
LLM_API_KEY=your-openai-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# 向量数据库
VECTOR_DB_PATH=E:/py项目/Skin diseases/chroma_db

# 加密
ENCRYPTION_KEY=32-char-encryption-key-here!!!

# 地图API
MAP_API_KEY=your-map-api-key

# 性能
DIAGNOSIS_TIMEOUT=3
CHAT_TIMEOUT=2
MAX_CONCURRENT=1000

# 多模式
SYSTEM_MODES=["production","development","test","demo"]
DEFAULT_MODE=production
